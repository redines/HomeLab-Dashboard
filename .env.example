# Example environment variables
# Copy this file to .env and adjust values

# Application Settings
# For development, DEBUG defaults to True (uses SQLite)
# For production, set DEBUG=False and configure database below
DEBUG=True
DJANGO_SECRET_KEY=your-secret-key-here-change-in-production
ALLOWED_HOSTS=localhost,127.0.0.1,homelab-dashboard

# Database Configuration (Only needed when DEBUG=False)
# Option 1: DATABASE_URL (recommended for production)
# DATABASE_URL=postgresql://user:password@host:5432/dbname
# DATABASE_URL=mysql://user:password@host:3306/dbname

# Option 2: Individual database settings (alternative to DATABASE_URL)
# DB_ENGINE=django.db.backends.postgresql
# DB_NAME=homelab_dashboard
# DB_USER=postgres
# DB_PASSWORD=your-db-password
# DB_HOST=localhost
# DB_PORT=5432

# Note: Install production requirements for PostgreSQL support:
#   pip install -r requirements-production.txt

# Traefik API Configuration
TRAEFIK_API_URL=http://traefik:8080/api
TRAEFIK_API_USERNAME=
TRAEFIK_API_PASSWORD=

# Field Encryption Key (OPTIONAL - auto-generated if not provided)
# The application will automatically generate and store an encryption key
# in .encryption_key file if you don't provide one here.
# Only set this if you want to use a specific key (e.g., in production clusters)
# FIELD_ENCRYPTION_KEY=your-encryption-key-here

# Service refresh interval in seconds
SERVICE_REFRESH_INTERVAL=60
